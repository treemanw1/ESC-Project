rningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"83","messages":"84","suppressedMessages":"85","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"86"},"C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src\\index.js",[],[],[],"C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src\\App.js",[],[],"C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src\\pages\\Hotel details\\HotelDetails.jsx",["87","88","89","90"],[],"C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src\\pages\\Destination search page\\DestinationSearchPage.jsx",["91"],[],"import Header from \"../../components/header/Header\";\r\nimport Navbar from \"../../components/navbar/Navbar\";\r\nimport \"./DestinationSearchPage.css\";\r\n\r\nimport { DateRange } from \"react-date-range\";\r\nimport { useState } from \"react\";\r\nimport \"react-date-range/dist/styles.css\"; // main css file\r\nimport \"react-date-range/dist/theme/default.css\"; // theme css file\r\nimport { format } from \"date-fns\";\r\nimport { useNavigate } from \"react-router-dom\";\r\n\r\nconst Home = ({ type }) => {\r\n  const [destination, setDestination] = useState(\"\");\r\n  const [openDate, setOpenDate] = useState(false);\r\n  const [date, setDate] = useState([\r\n    {\r\n      startDate: new Date(),\r\n      endDate: new Date(),\r\n      key: \"selection\",\r\n    },\r\n  ]);\r\n  const [openOptions, setOpenOptions] = useState(false);\r\n  const [options, setOptions] = useState({\r\n    adult: 1,\r\n    children: 0,\r\n    room: 1,\r\n  });\r\n\r\n  const navigate = useNavigate();\r\n\r\n  const handleOption = (name, operation) => {\r\n    setOptions((prev) => {\r\n      return {\r\n        ...prev,\r\n        [name]: operation === \"i\" ? options[name] + 1 : options[name] - 1,\r\n      };\r\n    });\r\n  };\r\n\r\n  const handleSearch = () => {\r\n    navigate(\"/hotels\", { state: { destination, date, options } });\r\n  };\r\n\r\n  return (\r\n    <div>\r\n      <Navbar />\r\n      {/* <Test/>  */}\r\n      <div className=\"homeContainer\">\r\n        <div class=\"childHomeContainer\">\r\n          <div className=\"question\">\r\n            <div class=\"text\">Where</div>\r\n            <div class=\"text\">are you</div>\r\n            <div class=\"text\">travelling to?</div>\r\n          </div>\r\n\r\n          <div className=\"search\">\r\n            <div className=\"headerSearchItem1\">\r\n              <div className=\"spaceItem\">DESTINATION</div>\r\n              <div className=\"destinationSearchInput\">\r\n                <input\r\n                  type=\"text\"\r\n                  placeholder=\"Enter Destination\"\r\n                  className=\"headerSearchInput\"\r\n                  onChange={(e) => setDestination(e.target.value)}\r\n                />\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"spaceItem\">\r\n              <div className=\"spaceItem\">CHECKING DATES</div>\r\n              <div className=\"dateItem\">\r\n                <span\r\n                  onClick={() => setOpenDate(!openDate)}\r\n                  className=\"dateItem\"\r\n                >{`${format(date[0].startDate, \"MMM dd, yyyy\")} to ${format(\r\n                  date[0].endDate,\r\n                  \"MMM dd, yyyy\"\r\n                )}`}</span>\r\n                {openDate && (\r\n                  <DateRange\r\n                    editableDateInputs={true}\r\n                    onChange={(item) => setDate([item.selection])}\r\n                    moveRangeOnFirstSelection={false}\r\n                    ranges={date}\r\n                    className=\"date\"\r\n                    minDate={new Date()}\r\n                  />\r\n                )}\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"searchContainer\">\r\n              <div className=\"childSearchContainer\">\r\n                <div className=\"spaceItem\"> ADULTS </div>\r\n                <div className=\"countItem\">\r\n                  <span\r\n                    onClick={() => setOpenOptions(!openOptions)}\r\n                    className=\"countItem\"\r\n                  >{`${options.adult}`}</span>\r\n                  {openOptions && (\r\n                    <div className=\"options\">\r\n                      <div className=\"optionItem\">\r\n                        <span className=\"optionText\">Adults</span>\r\n                        <div className=\"optionCounter\">\r\n                          <button\r\n                            disabled={options.adult <= 1}\r\n                            className=\"optionCounterButton\"\r\n                            onClick={() => handleOption(\"adult\", \"d\")}\r\n                          >\r\n                            -\r\n                          </button>\r\n                          <span className=\"optionCounterNumber\">\r\n                            {options.adult}\r\n                          </span>\r\n                          <button\r\n                            className=\"optionCounterButton\"\r\n                            onClick={() => handleOption(\"adult\", \"i\")}\r\n                          >\r\n                            +\r\n                          </button>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"childSearchContainer\">\r\n                <div className=\"spaceItem\"> CHILDREN </div>\r\n                <div className=\"countItem\">\r\n                  <span\r\n                    onClick={() => setOpenOptions(!openOptions)}\r\n                    className=\"countItem\"\r\n                    // {`${options.adult} adult · ${options.children} children · ${options.room} room`}\r\n                  >{`${options.children}`}</span>\r\n                  {openOptions && (\r\n                    <div className=\"options\">\r\n                      <div className=\"optionItem\">\r\n                        <span className=\"optionText\">Children</span>\r\n                        <div className=\"optionCounter\">\r\n                          <button\r\n                            disabled={options.children <= 0}\r\n                            className=\"optionCounterButton\"\r\n                            onClick={() => handleOption(\"children\", \"d\")}\r\n                          >\r\n                            -\r\n                          </button>\r\n                          <span className=\"optionCounterNumber\">\r\n                            {options.children}\r\n                          </span>\r\n                          <button\r\n                            className=\"optionCounterButton\"\r\n                            onClick={() => handleOption(\"children\", \"i\")}\r\n                          >\r\n                            +\r\n                          </button>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"childSearchContainer\">\r\n                <div className=\"spaceItem\"> ROOMS </div>\r\n                <div className=\"countItem\">\r\n                  <span\r\n                    onClick={() => setOpenOptions(!openOptions)}\r\n                    className=\"countItem\"\r\n                  >\r\n                    {`${options.room}`}\r\n                  </span>\r\n                  {openOptions && (\r\n                    <div className=\"options\">\r\n                      <div className=\"optionItem\">\r\n                        <span className=\"optionText\">Rooms</span>\r\n                        <div className=\"optionCounter\">\r\n                          <button\r\n                            disabled={options.room <= 1}\r\n                            className=\"optionCounterButton\"\r\n                            onClick={() => handleOption(\"room\", \"d\")}\r\n                          >\r\n                            -\r\n                          </button>\r\n                          <span className=\"optionCounterNumber\">\r\n                            {options.room}\r\n                          </span>\r\n                          <button\r\n                            className=\"optionCounterButton\"\r\n                            onClick={() => handleOption(\"room\", \"i\")}\r\n                          >\r\n                            +\r\n                          </button>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"checkItem\">\r\n              <button className=\"searchButton\" onClick={handleSearch}>\r\n                Search\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Home;\r\n","C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src\\pages\\hotel\\Hotel.jsx",["92"],[],"import \"./hotel.css\";\r\nimport Navbar from \"../../components/navbar/Navbar\";\r\nimport Header from \"../../components/header/Header\";\r\n\r\nimport { FontAwesomeIcon } from \"@fortawesome/react-fontawesome\";\r\nimport {\r\n  faCircleArrowLeft,\r\n  faCircleArrowRight,\r\n  faCircleXmark,\r\n  faLocationDot,\r\n} from \"@fortawesome/free-solid-svg-icons\";\r\nimport { useState } from \"react\";\r\n\r\nconst Hotel = () => {\r\n  const [slideNumber, setSlideNumber] = useState(0);\r\n  const [open, setOpen] = useState(false);\r\n\r\n  const photos = [\r\n    {\r\n      src: \"https://cf.bstatic.com/xdata/images/hotel/max1280x900/261707778.jpg?k=56ba0babbcbbfeb3d3e911728831dcbc390ed2cb16c51d88159f82bf751d04c6&o=&hp=1\",\r\n    },\r\n    {\r\n      src: \"https://cf.bstatic.com/xdata/images/hotel/max1280x900/261707367.jpg?k=cbacfdeb8404af56a1a94812575d96f6b80f6740fd491d02c6fc3912a16d8757&o=&hp=1\",\r\n    },\r\n    {\r\n      src: \"https://cf.bstatic.com/xdata/images/hotel/max1280x900/261708745.jpg?k=1aae4678d645c63e0d90cdae8127b15f1e3232d4739bdf387a6578dc3b14bdfd&o=&hp=1\",\r\n    },\r\n    {\r\n      src: \"https://cf.bstatic.com/xdata/images/hotel/max1280x900/261707776.jpg?k=054bb3e27c9e58d3bb1110349eb5e6e24dacd53fbb0316b9e2519b2bf3c520ae&o=&hp=1\",\r\n    },\r\n    {\r\n      src: \"https://cf.bstatic.com/xdata/images/hotel/max1280x900/261708693.jpg?k=ea210b4fa329fe302eab55dd9818c0571afba2abd2225ca3a36457f9afa74e94&o=&hp=1\",\r\n    },\r\n    {\r\n      src: \"https://cf.bstatic.com/xdata/images/hotel/max1280x900/261707389.jpg?k=52156673f9eb6d5d99d3eed9386491a0465ce6f3b995f005ac71abc192dd5827&o=&hp=1\",\r\n    },\r\n  ];\r\n\r\n  const handleOpen = (i) => {\r\n    setSlideNumber(i);\r\n    setOpen(true);\r\n  };\r\n\r\n  const handleMove = (direction) => {\r\n    let newSlideNumber;\r\n\r\n    if (direction === \"l\") {\r\n      newSlideNumber = slideNumber === 0 ? 5 : slideNumber - 1;\r\n    } else {\r\n      newSlideNumber = slideNumber === 5 ? 0 : slideNumber + 1;\r\n    }\r\n\r\n    setSlideNumber(newSlideNumber);\r\n  };\r\n\r\n  return (\r\n    <div>\r\n      <div className=\"background\">\r\n        <Navbar />\r\n        <div className=\"hotelContainer\">\r\n          {open && (\r\n            <div className=\"slider\">\r\n              <FontAwesomeIcon\r\n                icon={faCircleXmark}\r\n                className=\"close\"\r\n                onClick={() => setOpen(false)}\r\n              />\r\n              <FontAwesomeIcon\r\n                icon={faCircleArrowLeft}\r\n                className=\"arrow\"\r\n                onClick={() => handleMove(\"l\")}\r\n              />\r\n              <div className=\"sliderWrapper\">\r\n                <img\r\n                  src={photos[slideNumber].src}\r\n                  alt=\"\"\r\n                  className=\"sliderImg\"\r\n                />\r\n              </div>\r\n              <FontAwesomeIcon\r\n                icon={faCircleArrowRight}\r\n                className=\"arrow\"\r\n                onClick={() => handleMove(\"r\")}\r\n              />\r\n            </div>\r\n          )}\r\n          <div className=\"hotelWrapper\">\r\n            <button className=\"bookNow\">Reserve or Book Now!</button>\r\n            <h1 className=\"hotelTitle\">Tower Street Apartments</h1>\r\n            <div className=\"hotelAddress\">\r\n              <FontAwesomeIcon icon={faLocationDot} />\r\n              <span>Elton St 125 New york</span>\r\n            </div>\r\n            <span className=\"hotelDistance\">\r\n              Excellent location – 500m from center\r\n            </span>\r\n            <span className=\"hotelPriceHighlight\">\r\n              Book a stay over $114 at this property and get a free airport taxi\r\n            </span>\r\n            <div className=\"hotelImages\">\r\n              {photos.map((photo, i) => (\r\n                <div className=\"hotelImgWrapper\" key={i}>\r\n                  <img\r\n                    onClick={() => handleOpen(i)}\r\n                    src={photo.src}\r\n                    alt=\"\"\r\n                    className=\"hotelImg\"\r\n                  />\r\n                </div>\r\n              ))}\r\n            </div>\r\n            <div className=\"hotelDetails\">\r\n              <div className=\"hotelDetailsTexts\">\r\n                <h1 className=\"hotelTitle\">Stay in the heart of City</h1>\r\n                <p className=\"hotelDesc\">\r\n                  Located a 5-minute walk from St. Florian's Gate in Krakow,\r\n                  Tower Street Apartments has accommodations with air\r\n                  conditioning and free WiFi. The units come with hardwood\r\n                  floors and feature a fully equipped kitchenette with a\r\n                  microwave, a flat-screen TV, and a private bathroom with\r\n                  shower and a hairdryer. A fridge is also offered, as well as\r\n                  an electric tea pot and a coffee machine. Popular points of\r\n                  interest near the apartment include Cloth Hall, Main Market\r\n                  Square and Town Hall Tower. The nearest airport is John Paul\r\n                  II International Kraków–Balice, 16.1 km from Tower Street\r\n                  Apartments, and the property offers a paid airport shuttle\r\n                  service.\r\n                </p>\r\n              </div>\r\n              <div className=\"hotelDetailsPrice\">\r\n                <h1>Perfect for a 9-night stay!</h1>\r\n                <span>\r\n                  Located in the real heart of Krakow, this property has an\r\n                  excellent location score of 9.8!\r\n                </span>\r\n                <h2>\r\n                  <b>$945</b> (9 nights)\r\n                </h2>\r\n                <button>Reserve or Book Now!</button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Hotel;\r\n","C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src\\pages\\list\\List.jsx",["93","94","95","96","97","98","99","100","101","102"],[],"C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src\\components\\header\\Header.jsx",["103","104","105","106","107","108","109"],[],"import {\r\n  faBed,\r\n  faCalendarDays,\r\n  faCar,\r\n  faPerson,\r\n  faPlane,\r\n  faTaxi,\r\n} from \"@fortawesome/free-solid-svg-icons\";\r\nimport { FontAwesomeIcon } from \"@fortawesome/react-fontawesome\";\r\nimport \"./header.css\";\r\nimport { DateRange } from \"react-date-range\";\r\nimport { useState } from \"react\";\r\nimport \"react-date-range/dist/styles.css\"; // main css file\r\nimport \"react-date-range/dist/theme/default.css\"; // theme css file\r\nimport { format } from \"date-fns\";\r\nimport { useNavigate } from \"react-router-dom\";\r\n\r\nconst Header = ({ type }) => {\r\n  const [destination, setDestination] = useState(\"\");\r\n  const [openDate, setOpenDate] = useState(false);\r\n  const [date, setDate] = useState([\r\n    {\r\n      startDate: new Date(),\r\n      endDate: new Date(),\r\n      key: \"selection\",\r\n    },\r\n  ]);\r\n  const [openOptions, setOpenOptions] = useState(false);\r\n  const [options, setOptions] = useState({\r\n    adult: 1,\r\n    children: 0,\r\n    room: 1,\r\n  });\r\n\r\n  const navigate = useNavigate();\r\n\r\n  const handleOption = (name, operation) => {\r\n    setOptions((prev) => {\r\n      return {\r\n        ...prev,\r\n        [name]: operation === \"i\" ? options[name] + 1 : options[name] - 1,\r\n      };\r\n    });\r\n  };\r\n\r\n  const handleSearch = () => {\r\n    navigate(\"/hotels\", { state: { destination, date, options } });\r\n  };\r\n\r\n  return (\r\n    <div className=\"header\">\r\n      <div\r\n        className={\r\n          type === \"list\" ? \"headerContainer listMode\" : \"headerContainer\"\r\n        }\r\n      >\r\n        {type !== \"list\" && (\r\n          <>\r\n            <div className=\"headerContainer\">\r\n              <div class=\"childHeaderContainer\">\r\n                <div className=\"destinationItem\">\r\n                  <div className=\"textItem\">DESTINATION</div>\r\n                  <div className=\"destinationSearchItem\">\r\n                    <input\r\n                      type=\"text\"\r\n                      color=\"black\"\r\n                      placeholder=\"Enter Destination\"\r\n                      className=\"headerSearchInput\"\r\n                      onChange={(e) => setDestination(e.target.value)}\r\n                    />\r\n                  </div>\r\n                </div>\r\n\r\n                <div className=\"textItem\">\r\n                  <div className=\"textItem\">CHECKING DATES</div>\r\n                  <div className=\"dateItem\">\r\n                    <span\r\n                      onClick={() => setOpenDate(!openDate)}\r\n                      className=\"dateItem\"\r\n                    >{`${format(date[0].startDate, \"MMM dd, yyyy\")} to ${format(\r\n                      date[0].endDate,\r\n                      \"MMM dd, yyyy\"\r\n                    )}`}</span>\r\n                    {openDate && (\r\n                      <DateRange\r\n                        editableDateInputs={true}\r\n                        onChange={(item) => setDate([item.selection])}\r\n                        moveRangeOnFirstSelection={false}\r\n                        ranges={date}\r\n                        className=\"date\"\r\n                        minDate={new Date()}\r\n                      />\r\n                    )}\r\n                  </div>\r\n                </div>\r\n\r\n                <div className=\"searchContainer\">\r\n                  <div className=\"childSearchContainer\">\r\n                    <div className=\"spaceItem\"> ADULTS </div>\r\n                    <div className=\"countItem\">\r\n                      <span\r\n                        onClick={() => setOpenOptions(!openOptions)}\r\n                        className=\"countItem\"\r\n                      >{`${options.adult}`}</span>\r\n                      {openOptions && (\r\n                        <div className=\"options\">\r\n                          <div className=\"optionItem\">\r\n                            <span className=\"optionText\">Adults</span>\r\n                            <div className=\"optionCounter\">\r\n                              <button\r\n                                disabled={options.adult <= 1}\r\n                                className=\"optionCounterButton\"\r\n                                onClick={() => handleOption(\"adult\", \"d\")}\r\n                              >\r\n                                -\r\n                              </button>\r\n                              <span className=\"optionCounterNumber\">\r\n                                {options.adult}\r\n                              </span>\r\n                              <button\r\n                                className=\"optionCounterButton\"\r\n                                onClick={() => handleOption(\"adult\", \"i\")}\r\n                              >\r\n                                +\r\n                              </button>\r\n                            </div>\r\n                          </div>\r\n                        </div>\r\n                      )}\r\n                    </div>\r\n                  </div>\r\n\r\n                  <div className=\"childSearchContainer\">\r\n                    <div className=\"spaceItem\"> CHILDREN </div>\r\n                    <div className=\"countItem\">\r\n                      <span\r\n                        onClick={() => setOpenOptions(!openOptions)}\r\n                        className=\"countItem\"\r\n                        // {`${options.adult} adult · ${options.children} children · ${options.room} room`}\r\n                      >{`${options.children}`}</span>\r\n                      {openOptions && (\r\n                        <div className=\"options\">\r\n                          <div className=\"optionItem\">\r\n                            <span className=\"optionText\">Children</span>\r\n                            <div className=\"optionCounter\">\r\n                              <button\r\n                                disabled={options.children <= 0}\r\n                                className=\"optionCounterButton\"\r\n                                onClick={() => handleOption(\"children\", \"d\")}\r\n                              >\r\n                                -\r\n                              </button>\r\n                              <span className=\"optionCounterNumber\">\r\n                                {options.children}\r\n                              </span>\r\n                              <button\r\n                                className=\"optionCounterButton\"\r\n                                onClick={() => handleOption(\"children\", \"i\")}\r\n                              >\r\n                                +\r\n                              </button>\r\n                            </div>\r\n                          </div>\r\n                        </div>\r\n                      )}\r\n                    </div>\r\n                  </div>\r\n\r\n                  <div className=\"childSearchContainer\">\r\n                    <div className=\"spaceItem\"> ROOMS </div>\r\n                    <div className=\"countItem\">\r\n                      <span\r\n                        onClick={() => setOpenOptions(!openOptions)}\r\n                        className=\"countItem\"\r\n                      >\r\n                        {`${options.room}`}\r\n                      </span>\r\n                      {openOptions && (\r\n                        <div className=\"options\">\r\n                          <div className=\"optionItem\">\r\n                            <span className=\"optionText\">Rooms</span>\r\n                            <div className=\"optionCounter\">\r\n                              <button\r\n                                disabled={options.room <= 1}\r\n                                className=\"optionCounterButton\"\r\n                                onClick={() => handleOption(\"room\", \"d\")}\r\n                              >\r\n                                -\r\n                              </button>\r\n                              <span className=\"optionCounterNumber\">\r\n                                {options.room}\r\n                              </span>\r\n                              <button\r\n                                className=\"optionCounterButton\"\r\n                                onClick={() => handleOption(\"room\", \"i\")}\r\n                              >\r\n                                +\r\n                              </button>\r\n                            </div>\r\n                          </div>\r\n                        </div>\r\n                      )}\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                <div className=\"updateItem\">\r\n                  <button className=\"searchBtn\" onClick={handleSearch}>\r\n                    Modify Search\r\n                  </button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </>\r\n        )}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Header;\r\n","C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src\\components\\navbar\\Navbar.jsx",[],[],"C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src\\pages\\list\\info.jsx",[],[],"C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src\\components\\map\\Map.jsx",[],[],"C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src\\components\\searchItem\\SearchItem.jsx",[],[],"C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src\\components\\star\\Star.jsx",[],[],"C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src\\pages\\b