te, setDate] = useState([\r\n    {\r\n      startDate: new Date(),\r\n      endDate: new Date(),\r\n      key: \"selection\",\r\n    },\r\n  ]);\r\n  const [openOptions, setOpenOptions] = useState(false);\r\n  const [options, setOptions] = useState({\r\n    adult: 1,\r\n    children: 0,\r\n    room: 1,\r\n  });\r\n\r\n  const navigate = useNavigate();\r\n\r\n  const handleOption = (name, operation) => {\r\n    setOptions((prev) => {\r\n      return {\r\n        ...prev,\r\n        [name]: operation === \"i\" ? options[name] + 1 : options[name] - 1,\r\n      };\r\n    });\r\n  };\r\n\r\n  const handleSearch = () => {\r\n    navigate(\"/hotels\", { state: { destination, date, options } });\r\n  };\r\n\r\n  return (\r\n    <div>\r\n      <Navbar />\r\n      {/* <Test/>  */}\r\n      <div className=\"homeContainer\">\r\n        <div class=\"childHomeContainer\">\r\n          <div className=\"question\">\r\n            <div class=\"text\">Where</div>\r\n            <div class=\"text\">are you</div>\r\n            <div class=\"text\">travelling to?</div>\r\n          </div>\r\n\r\n          <div className=\"search\">\r\n            <div className=\"headerSearchItem1\">\r\n              <div className=\"spaceItem\">DESTINATION</div>\r\n              <div className=\"destinationSearchInput\">\r\n                <input\r\n                  type=\"text\"\r\n                  placeholder=\"Enter Destination\"\r\n                  className=\"headerSearchInput\"\r\n                  onChange={(e) => setDestination(e.target.value)}\r\n                />\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"spaceItem\">\r\n              <div className=\"spaceItem\">CHECKING DATES</div>\r\n              <div className=\"dateItem\">\r\n                <span\r\n                  onClick={() => setOpenDate(!openDate)}\r\n                  className=\"dateItem\"\r\n                >{`${format(date[0].startDate, \"MMM dd, yyyy\")} to ${format(\r\n                  date[0].endDate,\r\n                  \"MMM dd, yyyy\"\r\n                )}`}</span>\r\n                {openDate && (\r\n                  <DateRange\r\n                    editableDateInputs={true}\r\n                    onChange={(item) => setDate([item.selection])}\r\n                    moveRangeOnFirstSelection={false}\r\n                    ranges={date}\r\n                    className=\"date\"\r\n                    minDate={new Date()}\r\n                  />\r\n                )}\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"searchContainer\">\r\n              <div className=\"childSearchContainer\">\r\n                <div className=\"spaceItem\"> ADULTS </div>\r\n                <div className=\"countItem\">\r\n                  <span\r\n                    onClick={() => setOpenOptions(!openOptions)}\r\n                    className=\"countItem\"\r\n                  >{`${options.adult}`}</span>\r\n                  {openOptions && (\r\n                    <div className=\"options\">\r\n                      <div className=\"optionItem\">\r\n                        <span className=\"optionText\">Adults</span>\r\n                        <div className=\"optionCounter\">\r\n                          <button\r\n                            disabled={options.adult <= 1}\r\n                            className=\"optionCounterButton\"\r\n                            onClick={() => handleOption(\"adult\", \"d\")}\r\n                          >\r\n                            -\r\n                          </button>\r\n                          <span className=\"optionCounterNumber\">\r\n                            {options.adult}\r\n                          </span>\r\n                          <button\r\n                            className=\"optionCounterButton\"\r\n                            onClick={() => handleOption(\"adult\", \"i\")}\r\n                          >\r\n                            +\r\n                          </button>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"childSearchContainer\">\r\n                <div className=\"spaceItem\"> CHILDREN </div>\r\n                <div className=\"countItem\">\r\n                  <span\r\n                    onClick={() => setOpenOptions(!openOptions)}\r\n                    className=\"countItem\"\r\n                    // {`${options.adult} adult · ${options.children} children · ${options.room} room`}\r\n                  >{`${options.children}`}</span>\r\n                  {openOptions && (\r\n                    <div className=\"options\">\r\n                      <div className=\"optionItem\">\r\n                        <span className=\"optionText\">Children</span>\r\n                        <div className=\"optionCounter\">\r\n                          <button\r\n                            disabled={options.children <= 0}\r\n                            className=\"optionCounterButton\"\r\n                            onClick={() => handleOption(\"children\", \"d\")}\r\n                          >\r\n                            -\r\n                          </button>\r\n                          <span className=\"optionCounterNumber\">\r\n                            {options.children}\r\n                          </span>\r\n                          <button\r\n                            className=\"optionCounterButton\"\r\n                            onClick={() => handleOption(\"children\", \"i\")}\r\n                          >\r\n                            +\r\n                          </button>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"childSearchContainer\">\r\n                <div className=\"spaceItem\"> ROOMS </div>\r\n                <div className=\"countItem\">\r\n                  <span\r\n                    onClick={() => setOpenOptions(!openOptions)}\r\n                    className=\"countItem\"\r\n                  >\r\n                    {`${options.room}`}\r\n                  </span>\r\n                  {openOptions && (\r\n                    <div className=\"options\">\r\n                      <div className=\"optionItem\">\r\n                        <span className=\"optionText\">Rooms</span>\r\n                        <div className=\"optionCounter\">\r\n                          <button\r\n                            disabled={options.room <= 1}\r\n                            className=\"optionCounterButton\"\r\n                            onClick={() => handleOption(\"room\", \"d\")}\r\n                          >\r\n                            -\r\n                          </button>\r\n                          <span className=\"optionCounterNumber\">\r\n                            {options.room}\r\n                          </span>\r\n                          <button\r\n                            className=\"optionCounterButton\"\r\n                            onClick={() => handleOption(\"room\", \"i\")}\r\n                          >\r\n                            +\r\n                          </button>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"checkItem\">\r\n              <button className=\"searchButton\" onClick={handleSearch}>\r\n                Search\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Home;\r\n","C:\\Users\\annma\\OneDrive\\Documents\\Ann SUTD Files\\Term 5\\ESC\\ESC- Project\\ESC-Project-1\\client\\src