","messageId":"114","endLine":18,"endColumn":18},{"ruleId":"111","severity":1,"message":"123","line":18,"column":20,"nodeType":"113","messageId":"114","endLine":18,"endColumn":31},{"ruleId":"111","severity":1,"message":"124","line":19,"column":10,"nodeType":"113","messageId":"114","endLine":19,"endColumn":17},{"ruleId":"111","severity":1,"message":"125","line":19,"column":19,"nodeType":"113","messageId":"114","endLine":19,"endColumn":29},{"ruleId":"111","severity":1,"message":"126","line":22,"column":9,"nodeType":"113","messageId":"114","endLine":22,"endColumn":25},{"ruleId":"111","severity":1,"message":"127","line":2,"column":3,"nodeType":"113","messageId":"114","endLine":2,"endColumn":8},{"ruleId":"111","severity":1,"message":"128","line":3,"column":3,"nodeType":"113","messageId":"114","endLine":3,"endColumn":17},{"ruleId":"111","severity":1,"message":"129","line":4,"column":3,"nodeType":"113","messageId":"114","endLine":4,"endColumn":8},{"ruleId":"111","severity":1,"message":"130","line":5,"column":3,"nodeType":"113","messageId":"114","endLine":5,"endColumn":11},{"ruleId":"111","severity":1,"message":"131","line":6,"column":3,"nodeType":"113","messageId":"114","endLine":6,"endColumn":10},{"ruleId":"111","severity":1,"message":"132","line":7,"column":3,"nodeType":"113","messageId":"114","endLine":7,"endColumn":9},{"ruleId":"111","severity":1,"message":"133","line":9,"column":10,"nodeType":"113","messageId":"114","endLine":9,"endColumn":25},{"ruleId":"134","severity":1,"message":"135","line":23,"column":17,"nodeType":"136","messageId":"137","endLine":23,"endColumn":18,"fix":"138"},"no-unused-vars","'SearchItem' is defined but never used.","Identifier","unusedVar","'GoogleMap' is defined but never used.","'Marker' is defined but never used.","'handleMoreImage' is assigned a value but never used.","'Header' is defined but never used.","'destination' is assigned a value but never used.","'date' is assigned a value but never used.","'setDate' is assigned a value but ne